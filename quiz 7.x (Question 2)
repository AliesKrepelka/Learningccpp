
//constants.h
#ifndef constants_h
#define constants_h

 namespace Constants{
    inline constexpr int maxClassSize {35}; 
}

#endif

-------------------------------------------------------------------------
//main.cpp
#include "constants.h"
#include <iostream>

int main()
{
	std::cout << "How many students are in your class? ";
	int students{};
	std::cin >> students;


	if (students > Constants::maxClassSize)
		std::cout << "There are too many students in this class";
	else
		std::cout << "This class isn't too large";

	return 0;
}
